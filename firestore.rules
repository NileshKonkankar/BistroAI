rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- GLOBAL HELPERS (Phase 3) ---
    function isSignedIn() { return request.auth != null; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    // Bootstrap Admin: Hardcoding your email as a "Super Admin" for the demo environment
    function isSuperAdmin() {
      return isSignedIn() && (request.auth.token.email == 'KonkankarNilesh@gmail.com' || request.auth.token.email == 'konkankarnilesh@gmail.com');
    }

    function getUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }

    function isRole(role) {
      // Order is important for short-circuiting: Super Admin check first to avoid dependency on user doc existence
      return isSuperAdmin() || (isSignedIn() && getUserData(request.auth.uid).get('role', 'customer') == role);
    }

    function isAdmin() { return isRole('admin'); }
    function isStaff() { return isRole('staff') || isAdmin(); }

    // --- ENTITY VALIDATION (Phase 4) ---

    function isValidUser(data) {
      return data.email is string && data.email.size() < 256 &&
             data.role in ['admin', 'staff', 'customer'];
    }

    function isValidMenuItem(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.price is number && data.price >= 0 &&
             data.category is string &&
             data.available is bool;
    }

    function isValidOrder(data) {
      return data.totalAmount is number && data.totalAmount >= 0 &&
             data.status in ['pending', 'preparing', 'ready', 'delivered', 'cancelled'] &&
             data.items is list && data.items.size() > 0 &&
             (data.customerId == request.auth.uid || isAdmin());
    }

    // --- COLLECTION MATCHES ---

    match /users/{userId} {
      allow read: if isSignedIn();
      // Allow creation/updates if it's the user themselves or the super admin
      // We allow self-role updates on creation/update for this demo specifically
      allow create: if isSignedIn() && (request.auth.uid == userId || isSuperAdmin()) && isValidUser(incoming());
      allow update: if isSignedIn() && (request.auth.uid == userId || isSuperAdmin());
    }

    match /menu/{itemId} {
      allow read: if true; 
      allow create: if isStaff() && isValidMenuItem(incoming());
      allow update: if isStaff() && isValidMenuItem(incoming());
      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      // allow list: Must evaluate existing data
      allow list: if isSignedIn() && (resource.data.customerId == request.auth.uid || isStaff());
      allow get: if isSignedIn() && (resource.data.customerId == request.auth.uid || isStaff());
      
      allow create: if isSignedIn() && 
                    isValidOrder(incoming()) &&
                    incoming().createdAt == request.time;
                    
      allow update: if isSignedIn() && (
        // Staff action: Update status or table
        (isStaff() && incoming().diff(existing()).affectedKeys().hasAny(['status', 'tableNumber', 'updatedAt']) && 
         incoming().diff(existing()).affectedKeys().hasOnly(['status', 'tableNumber', 'updatedAt'])) ||
        // Customer action: Cancel pending order
        (existing().customerId == request.auth.uid && existing().status == 'pending' && incoming().status == 'cancelled')
      );
      allow delete: if isAdmin();
    }

    match /inventory/{itemId} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn() && incoming().customerId == request.auth.uid;
      allow delete: if isAdmin();
    }

    match /tables/{tableId} {
      allow read: if isSignedIn();
      allow write: if isStaff();
    }
    
    // Connectivity Test
    match /test/connection {
      allow read: if true;
    }
  }
}
