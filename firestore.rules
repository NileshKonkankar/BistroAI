rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- GLOBAL HELPERS (Phase 3) ---
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    // Bootstrap Admin: Hardcoding your email as a "Super Admin" for the demo environment
    function isSuperAdmin() {
      return isVerified() && (request.auth.token.email == 'KonkankarNilesh@gmail.com' || request.auth.token.email == 'konkankarnilesh@gmail.com');
    }

    function getUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }

    function isRole(role) {
      // Order is important for short-circuiting: Super Admin check first to avoid dependency on user doc existence
      return isSuperAdmin() || (isVerified() && getUserData(request.auth.uid).get('role', 'customer') == role);
    }

    function isAdmin() { return isRole('admin'); }
    function isStaff() { return isRole('staff') || isAdmin(); }

    // --- ENTITY VALIDATION (Phase 4) ---

    function isValidUser(data) {
      return data.email is string && data.email.size() < 256 &&
             data.role in ['admin', 'staff', 'customer'];
    }

    function isValidMenuItem(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.price is number && data.price >= 0 &&
             data.category is string &&
             data.available is bool &&
             (!('tags' in data) || data.tags is list);
    }

    function isValidOrder(data) {
      return data.totalAmount is number && data.totalAmount >= 0 &&
             data.status in ['pending', 'preparing', 'ready', 'delivered', 'cancelled'] &&
             data.items is list && data.items.size() > 0 &&
             (data.customerId == request.auth.uid || isAdmin());
    }

    // --- COLLECTION MATCHES ---

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isStaff());
      // Allow creation/updates if it's the user themselves or the super admin
      allow create: if isVerified() && isValidId(userId) && (request.auth.uid == userId || isSuperAdmin()) && isValidUser(incoming());
      allow update: if isVerified() && isValidId(userId) && (request.auth.uid == userId || isSuperAdmin()) && 
                    incoming().email == existing().email &&
                    (isSuperAdmin() || incoming().role == existing().role);
    }

    match /menu/{itemId} {
      allow read: if true; 
      allow create: if isStaff() && isValidId(itemId) && isValidMenuItem(incoming());
      allow update: if isStaff() && isValidId(itemId) && isValidMenuItem(incoming());
      allow delete: if isAdmin() && isValidId(itemId);
    }

    match /orders/{orderId} {
      // allow list: Must evaluate existing data
      allow list: if isSignedIn() && (resource.data.customerId == request.auth.uid || isStaff());
      allow get: if isSignedIn() && isValidId(orderId) && (resource.data.customerId == request.auth.uid || isStaff());
      
      allow create: if isVerified() && 
                    isValidId(orderId) &&
                    isValidOrder(incoming()) &&
                    incoming().createdAt == request.time;
                    
      allow update: if isVerified() && isValidId(orderId) && (
        // Staff action: Update status or table
        (isStaff() && incoming().diff(existing()).affectedKeys().hasAny(['status', 'tableNumber', 'updatedAt']) && 
         incoming().diff(existing()).affectedKeys().hasOnly(['status', 'tableNumber', 'updatedAt']) &&
         incoming().status != existing().status) ||
        // Customer action: Cancel pending order
        (existing().customerId == request.auth.uid && existing().status == 'pending' && 
         incoming().status == 'cancelled' && 
         incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']))
      ) && incoming().customerId == existing().customerId && incoming().createdAt == existing().createdAt;
      allow delete: if isAdmin() && isValidId(orderId);
    }

    match /inventory/{itemId} {
      allow read: if isStaff() && isValidId(itemId);
      allow write: if isAdmin() && isValidId(itemId);
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isVerified() && isValidId(reviewId) && incoming().customerId == request.auth.uid;
      allow delete: if isAdmin() && isValidId(reviewId);
    }

    match /tables/{tableId} {
      allow read: if isSignedIn();
      allow write: if isStaff() && isValidId(tableId);
    }
    
    // Connectivity Test
    match /test/connection {
      allow read: if true;
    }
  }
}
